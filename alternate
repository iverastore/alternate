        Library:ChangeTheme({"Text", "Unselected"}, tableToColor(data.TextUnsel))
        Library:ChangeTheme({"Borders", "Outline"}, tableToColor(data.Outline))
        Library:ChangeTheme({"Borders", "Inline"}, tableToColor(data.Border))
    end)
end

