do
local ChamsPage = Window:Page({ Name = "Chams", Icon = "rbxassetid://117259180607823" })
local ChamsTab = ChamsPage:Section({ Name = "Chams", Side = 1 })
local ChamsTabR = ChamsTab

local updateChams = LPH_NO_VIRTUALIZE(function()
    local enabled = Flags["PlayerChams"]
    local showSelf = Flags["ChamsShowSelf"]
    local showOthers = Flags["ChamsShowOthers"]
    local showNPCs = Flags["ChamsShowNPCs"]
    local checks = Flags["ChamsChecks"] or {}
    if type(checks) ~= "table" then checks = {} end
    local checkWall = hasCheck(checks, "Wall")
    local checkDead = hasCheck(checks, "Dead")

    local fillColor = getColor("ChamsFillColor", Color3.fromRGB(255, 0, 0))
    local outlineColor = getColor("ChamsOutlineColor", Color3.fromRGB(255, 255, 255))
    local fillTrans = (Flags["ChamsFillTransparency"] or 50) / 100
    local outlineTrans = (Flags["ChamsOutlineTransparency"] or 0) / 100
    local alwaysOnTop = Flags["ChamsAlwaysOnTop"] or false
    local outlineOnly = Flags["ChamsOutlineOnly"] or false

    local function applyHighlight(char)
        if not char then return end
        local hl = char:FindFirstChild("_Chams")
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "_Chams"
        end
        hl.FillColor = fillColor
        hl.OutlineColor = outlineColor
        hl.FillTransparency = outlineOnly and 1 or fillTrans
        hl.OutlineTransparency = outlineTrans
        hl.DepthMode = alwaysOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
        if hl.Parent ~= char then
            hl.Parent = char
        end
    end

    local function removeHighlight(char)
        if not char then return end
        local hl = char:FindFirstChild("_Chams")
        if hl then hl:Destroy() end
    end

    if not enabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then removeHighlight(p.Character) end
        end
        for _, bot in ipairs(getNPCs()) do
            removeHighlight(bot)
        end
        return
    end

    for _, p in ipairs(Players:GetPlayers()) do
        local char = p.Character
        if char then
            local isSelf = (p == lp)
            local shouldCham = isSelf and showSelf or (not isSelf and showOthers)
            if shouldCham then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local isDead = hum and (hum.Health <= 0 or isKnockedOrKO(char) or isDeadCheck(char))
                if checkDead and isDead then
                    removeHighlight(char)
                elseif checkWall and not isSelf then
                    local visible = false
                    local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
                    if hrp then
                        local origin = camera.CFrame.Position
                        local rayParams = RaycastParams.new()
                        rayParams.FilterType = Enum.RaycastFilterType.Exclude
                        rayParams.FilterDescendantsInstances = {lp.Character, char}
                        local res = workspace:Raycast(origin, hrp.Position - origin, rayParams)
                        if not res then
                            visible = true
                        end
                    end
                    if visible then
                        applyHighlight(char)
                    else
                        removeHighlight(char)
                    end
                else
                    applyHighlight(char)
                end
            else
                removeHighlight(char)
            end
        end
    end

    if showNPCs then
        for _, bot in ipairs(getNPCs()) do
            local hum = bot:FindFirstChildOfClass("Humanoid")
            local isDead = hum and (hum.Health <= 0 or isKnockedOrKO(bot) or isDeadCheck(bot))
            if checkDead and isDead then
                removeHighlight(bot)
            elseif checkWall then
                local visible = false
                local hrp = bot:FindFirstChild("HumanoidRootPart") or bot:FindFirstChild("Head")
                if hrp then
                    local origin = camera.CFrame.Position
                    local rayParams = RaycastParams.new()
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    rayParams.FilterDescendantsInstances = {lp.Character, bot}
                    local res = workspace:Raycast(origin, hrp.Position - origin, rayParams)
                    if not res then
                        visible = true
                    end
                end
                if visible then
                    applyHighlight(bot)
                else
                    removeHighlight(bot)
                end
            else
                applyHighlight(bot)
            end
        end
    else
        for _, bot in ipairs(getNPCs()) do
            removeHighlight(bot)
        end
    end
end)

task.spawn(function()
    while _scriptRunning do
        task.wait(0.05)
        pcall(updateChams)
