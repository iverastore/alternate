        local smoothX = Flags["SmoothX"] or 1
        local smoothY = Flags["SmoothY"] or 1
        if not Flags["UseSmoothingPlus"] then
            local amt = Flags["SmoothAmt"] or 1
            smoothX = amt
            smoothY = amt
        end
        smoothX = math.max(smoothX, 0.01)
        smoothY = math.max(smoothY, 0.01)
