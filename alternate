                    _aimEaseProgress = math.min(1, _aimEaseProgress + dt * easeSpeed * 3)
                    local easedT = applyEasing(_aimEaseProgress)
                    finalCF = camCF:Lerp(targetCF, math.clamp(easedT, 0.001, 1))
